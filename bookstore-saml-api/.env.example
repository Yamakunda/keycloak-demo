# Port the app listens on
PORT=3033
# Public base URL of this app (used for ACS/logout callback URLs and SP metadata)
BASE_URL=http://localhost:3033
# React frontend origin — CORS allow-list + redirect target after login/logout
FRONTEND_URL=http://localhost:3032
# Keycloak base URL (works from Docker too via extra_hosts: localhost:host-gateway)
KEYCLOAK_URL=http://localhost:8080
REALM=test
# SAML SP entityID — must match the Keycloak client's Client ID
SP_ENTITY_ID=bookstore-saml
# Secret for the express-session cookie
SESSION_SECRET=change-me
