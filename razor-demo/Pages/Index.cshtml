@page
@model IndexModel
@{
    ViewData["Title"] = "Home";
}

<div class="text-center">
    <h1 class="display-4">Keycloak OIDC Demo</h1>
    <p class="lead">ASP.NET Core Razor Pages + Keycloak (Authorization Code Flow)</p>

    @if (User.Identity?.IsAuthenticated == true)
    {
        <div class="alert alert-success d-inline-block">
            <p class="mb-1">Xin chào, <strong>@(User.FindFirst("name")?.Value ?? User.Identity.Name)</strong>!</p>
            <p class="mb-0 text-muted">@User.FindFirst("email")?.Value</p>
        </div>
        <div class="mt-3">
            <a class="btn btn-primary" asp-page="/Profile">Xem Profile (claims)</a>
            <form method="post" asp-page="/Account/Logout" class="d-inline">
                <button type="submit" class="btn btn-outline-danger">Logout</button>
            </form>
        </div>
    }
    else
    {
        <p>Bạn chưa đăng nhập.</p>
        <a class="btn btn-primary btn-lg" asp-page="/Account/Login">Login với Keycloak</a>
    }
</div>
